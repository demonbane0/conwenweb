---
interface Props {
  id?: string;
  class?: string;
}

const { id = "logo", class: className = "logo-mark" } = Astro.props;
const gradientId = `${id}-grad`;
---

<svg class={className} viewBox="0 0 40 40" role="img" aria-label="耕紋貿易標誌" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#205e9e"></stop>
      <stop offset="1" stop-color="#0d2f54"></stop>
    </linearGradient>
  </defs>
  <rect width="40" height="40" rx="9" fill={`url(#${gradientId})`}></rect>
  <path
    d="M6.5 24.5h5l3-11 4.5 15 3-9h5.5"
    fill="none"
    stroke="#ffffff"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle cx="31.5" cy="19.5" r="2.7" fill="#e8590c"></circle>
</svg>
