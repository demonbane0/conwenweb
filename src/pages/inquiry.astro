---
import { COMPANY, FORMSPREE_ENDPOINT } from "../data/site";
import Layout from "../layouts/Layout.astro";
import { withBase } from "../utils/url";
---

<Layout title="詢價單">
  <section
    class="section inquiry-page"
    id="inquiry-page"
    data-formspree-endpoint={FORMSPREE_ENDPOINT}
    data-company-email={COMPANY.email}
  >
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Inquiry</p>
        <h1>詢價單</h1>
        <p>確認產品與數量後，留下聯絡資訊送出詢價需求。</p>
      </div>

      <p class="form-message" data-inquiry-message role="status" aria-live="polite" hidden></p>

      <div class="card empty-inquiry" data-inquiry-empty hidden>
        <h2>詢價單是空的</h2>
        <p>請先到產品介紹加入需要詢價的產品。</p>
        <a class="btn btn-accent" href={withBase("/products/")}>瀏覽產品</a>
      </div>

      <div class="inquiry-content" data-inquiry-filled hidden>
        <div class="card inquiry-table-card">
          <div class="table-scroll">
            <table class="inquiry-table">
              <caption>
                已加入詢價單的產品
              </caption>
              <thead>
                <tr>
                  <th scope="col">型號</th>
                  <th scope="col">名稱</th>
                  <th scope="col">數量</th>
                  <th scope="col">移除</th>
                </tr>
              </thead>
              <tbody data-inquiry-items></tbody>
            </table>
          </div>
        </div>

        <form class="card inquiry-form" data-inquiry-form>
          <h2>聯絡資訊</h2>
          <div class="form-grid">
            <label>
              <span>公司名稱</span>
              <input type="text" name="company" autocomplete="organization" maxlength="100" />
            </label>
            <label>
              <span>聯絡人 *</span>
              <input type="text" name="contactPerson" autocomplete="name" required maxlength="50" />
            </label>
            <label>
              <span>電話 *</span>
              <input type="tel" name="phone" autocomplete="tel" required maxlength="30" inputmode="tel" />
            </label>
            <label>
              <span>Email *</span>
              <input type="email" name="email" autocomplete="email" required maxlength="100" />
            </label>
          </div>
          <label>
            <span>備註</span>
            <textarea name="notes" rows="5" maxlength="1000"></textarea>
          </label>
          <label class="gotcha-field" aria-hidden="true">
            <span>請勿填寫此欄位</span>
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </label>
          <button class="btn btn-accent form-submit" type="submit">送出詢價</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import "../scripts/inquiry";

  const root = document.querySelector<HTMLElement>("#inquiry-page");

  if (root) {
    const empty = root.querySelector<HTMLElement>("[data-inquiry-empty]");
    const filled = root.querySelector<HTMLElement>("[data-inquiry-filled]");
    const tbody = root.querySelector<HTMLTableSectionElement>("[data-inquiry-items]");
    const form = root.querySelector<HTMLFormElement>("[data-inquiry-form]");
    const message = root.querySelector<HTMLElement>("[data-inquiry-message]");
    const endpoint = root.dataset.formspreeEndpoint?.trim() ?? "";
    const companyEmail = root.dataset.companyEmail ?? "";
    const api = window.ConwenInquiry;

    const showMessage = (text: string, type: "success" | "error" | "notice") => {
      if (!message) {
        return;
      }

      message.textContent = text;
      message.dataset.type = type;
      message.hidden = false;
    };

    const productsText = () =>
      (api?.getItems() ?? [])
        .map((item) => `${item.model} x ${item.qty} ${item.title}`)
        .join("\n");

    const renderItems = () => {
      if (!api || !empty || !filled || !tbody) {
        return;
      }

      const items = api.getItems();
      empty.hidden = items.length > 0;
      filled.hidden = items.length === 0;
      tbody.replaceChildren();

      for (const item of items) {
        const row = document.createElement("tr");
        const model = document.createElement("td");
        const title = document.createElement("td");
        const qtyCell = document.createElement("td");
        const removeCell = document.createElement("td");
        const qty = document.createElement("input");
        const remove = document.createElement("button");

        model.textContent = item.model;
        title.textContent = item.title;
        qty.type = "number";
        qty.min = "1";
        qty.max = "999";
        qty.step = "1";
        qty.value = String(item.qty);
        qty.dataset.qtySlug = item.slug;
        qty.setAttribute("aria-label", `${item.model} 數量`);

        remove.type = "button";
        remove.className = "btn inquiry-remove";
        remove.textContent = "移除";
        remove.dataset.removeSlug = item.slug;
        remove.setAttribute("aria-label", `移除 ${item.model}`);

        qtyCell.append(qty);
        removeCell.append(remove);
        row.append(model, title, qtyCell, removeCell);
        tbody.append(row);
      }
    };

    tbody?.addEventListener("change", (event) => {
      const input = (event.target as Element).closest<HTMLInputElement>("[data-qty-slug]");

      if (!input || !api) {
        return;
      }

      api.setQty(input.dataset.qtySlug ?? "", Number.parseInt(input.value, 10));
      renderItems();
    });

    tbody?.addEventListener("click", (event) => {
      const button = (event.target as Element).closest<HTMLButtonElement>("[data-remove-slug]");

      if (!button || !api) {
        return;
      }

      api.remove(button.dataset.removeSlug ?? "");
      renderItems();
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!api || !form.reportValidity()) {
        return;
      }

      const items = api.getItems();

      if (items.length === 0) {
        showMessage("詢價單是空的", "error");
        return;
      }

      const formData = new FormData(form);
      const email = String(formData.get("email") ?? "").trim();
      const payload = {
        company: String(formData.get("company") ?? "").trim(),
        contactPerson: String(formData.get("contactPerson") ?? "").trim(),
        phone: String(formData.get("phone") ?? "").trim(),
        email,
        notes: String(formData.get("notes") ?? "").trim(),
        products: productsText(),
        _replyto: email,
        _gotcha: String(formData.get("_gotcha") ?? ""),
      };

      if (!payload.contactPerson) {
        showMessage("請填寫聯絡人姓名", "error");
        form.querySelector<HTMLInputElement>("[name=contactPerson]")?.focus();
        return;
      }

      const phoneDigits = payload.phone.replace(/\D/g, "");

      if (phoneDigits.length < 7) {
        showMessage("電話號碼看起來不完整，請確認後再送出（格式不限，含區碼即可）", "error");
        form.querySelector<HTMLInputElement>("[name=phone]")?.focus();
        return;
      }

      const sendViaMailto = (notice: string) => {
        const body = [
          "詢價產品：",
          productsText(),
          "",
          "聯絡資訊：",
          `公司名稱：${payload.company}`,
          `聯絡人：${payload.contactPerson}`,
          `電話：${payload.phone}`,
          `Email：${payload.email}`,
          "",
          "備註：",
          payload.notes,
        ].join("\n");

        window.location.href = `mailto:${companyEmail}?subject=${encodeURIComponent("詢價單")}&body=${encodeURIComponent(
          body,
        )}`;
        showMessage(notice, "notice");
      };

      if (endpoint) {
        const submitButton = form.querySelector<HTMLButtonElement>(".form-submit");

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = "送出中…";
        }

        try {
          const response = await fetch(endpoint, {
            method: "POST",
            headers: {
              Accept: "application/json",
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(`Formspree request failed: ${response.status}`);
          }

          api.clear();
          form.reset();
          showMessage("詢價已送出，我們會盡快與您聯絡。", "success");
          renderItems();
        } catch {
          // 線上送出失敗（額度用盡、服務中斷等）→ 自動退回 mailto，詢價不漏接
          sendViaMailto("線上送出暫時無法使用，已改為開啟您的郵件軟體，請按傳送完成詢價");
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = "送出詢價";
          }
        }

        return;
      }

      sendViaMailto("已開啟您的郵件軟體，請按傳送完成詢價");
    });

    window.addEventListener("inquiry:change", renderItems);
    renderItems();
  }
</script>

<style>
  .form-message {
    margin-bottom: var(--space-3);
    padding: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-section);
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .form-message[data-type="success"] {
    border-color: rgba(20, 70, 123, 0.28);
    background: #eef6ff;
  }

  .form-message[data-type="error"] {
    border-color: rgba(232, 89, 12, 0.32);
    background: var(--color-soft-accent);
  }

  .empty-inquiry,
  .inquiry-table-card,
  .inquiry-form {
    padding: var(--space-3);
  }

  .empty-inquiry h2 {
    margin-bottom: var(--space-1);
  }

  .inquiry-content {
    display: grid;
    gap: var(--space-3);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .inquiry-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
  }

  .inquiry-table caption {
    margin-bottom: var(--space-2);
    color: var(--color-primary-dark);
    font-size: 1.25rem;
    font-weight: 800;
    text-align: left;
  }

  .inquiry-table th,
  .inquiry-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    text-align: left;
    vertical-align: middle;
  }

  .inquiry-table th {
    color: var(--color-primary-dark);
    font-weight: 800;
  }

  .inquiry-table input {
    width: 6rem;
    min-height: 40px;
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .inquiry-remove {
    min-height: 40px;
    padding-inline: 0.85rem;
  }

  .inquiry-form {
    display: grid;
    gap: var(--space-3);
  }

  .inquiry-form h2 {
    margin-bottom: 0;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
  }

  .inquiry-form label {
    display: grid;
    gap: 0.35rem;
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .inquiry-form input,
  .inquiry-form textarea {
    width: 100%;
    min-height: 44px;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #ffffff;
    color: var(--color-text);
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }

  .inquiry-form textarea {
    resize: vertical;
  }

  .inquiry-form input:focus,
  .inquiry-form textarea:focus,
  .inquiry-table input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(20, 70, 123, 0.12);
    outline: none;
  }

  .form-submit {
    justify-self: start;
    min-width: 160px;
  }

  .form-submit:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  /* 蜜罐欄位：真人看不到、機器人會填，Formspree 會靜默丟棄 */
  .gotcha-field {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-submit {
      width: 100%;
    }
  }
</style>
