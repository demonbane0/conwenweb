---
import Layout from "../layouts/Layout.astro";
import { brands } from "../data/brands";
import { categories } from "../data/categories";
import { COMPANY } from "../data/site";
import { withBase } from "../utils/url";

const advantages = [
  {
    title: "專業代理數家知名廠牌",
    text: "長期代理歐、美、日知名測試測量儀器品牌，原廠貨源、品質有保障。",
  },
  {
    title: "產品種類繁多滿足各種應用",
    text: "十大分類、兩百餘項儀器，涵蓋電機、電子、環境、壓力、溫度與高壓維護等應用。",
  },
  {
    title: "合理價格專業服務",
    text: "專業團隊協助選型與報價，以合理的價格提供最適合的量測方案。",
  },
  {
    title: "北中南三據點即時服務與維修保固",
    text: "台北、台中、高雄皆設有服務據點，並有專屬維修部門提供保固與售後維修。",
  },
];
---

<Layout title="首頁">
  <section class="hero section">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Conwen Trading Co., Ltd.</p>
        <h1>{COMPANY.name}</h1>
        <p>專業代理進口電機電子測試測量儀器</p>
        <div class="hero-actions">
          <a class="btn btn-accent" href={withBase("/products/")}>瀏覽產品</a>
          <a class="btn" href={withBase("/inquiry/")}>立即詢價</a>
        </div>
      </div>
      <aside class="hero-panel" aria-label="公司服務摘要">
        <div class="hero-stat">
          <strong>1988</strong>
          <span>成立於民國 77 年</span>
        </div>
        <p>代理進口與國產測試測量儀器，服務電機、電子、維護、校正與工業現場應用。</p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">服務優勢</p>
        <h2>專業代理與在地服務</h2>
      </div>
      <div class="grid-4">
        {
          advantages.map((item) => (
            <article class="card feature-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">產品線</p>
        <h2>10 大產品分類</h2>
      </div>
      <div class="grid-3">
        {
          categories.map((category) => (
            <a class="card category-card" href={withBase(`/products/${category.slug}/`)}>
              <span class="category-order">{String(category.order).padStart(2, "0")}</span>
              <h3>{category.name}</h3>
              <p>查看此分類產品</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">合作品牌</p>
        <h2>代理廠牌</h2>
      </div>
      <div class="brand-strip">
        {
          brands.map((brand) => (
            <a class="brand-logo-box" href={withBase("/brands/")}>
              <img src={withBase(brand.image)} alt={`${brand.name} 標誌`} loading="lazy" />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-box">
      <div>
        <p class="eyebrow">聯絡耕紋</p>
        <h2>需要儀器選型或報價協助？</h2>
        <p>可透過詢價單或直接聯絡北中南據點，由專人回覆產品與服務需求。</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-accent" href={withBase("/inquiry/")}>立即詢價</a>
        <a class="btn" href={withBase("/contact/")}>聯絡我們</a>
      </div>
    </div>
  </section>
</Layout>
