---
import { getCollection, render } from "astro:content";
import ProductCard from "../../../components/ProductCard.astro";
import { categories } from "../../../data/categories";
import Layout from "../../../layouts/Layout.astro";
import { withBase } from "../../../utils/url";

export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map((product) => {
    const [category, slug] = product.id.split("/");

    return {
      params: { category, slug },
      props: { product },
    };
  });
}

const { product } = Astro.props;
const [categorySlug] = product.id.split("/");
const category = categories.find((item) => item.slug === categorySlug);
const { Content } = await render(product);

const relatedProducts = (await getCollection("products"))
  .filter((item) => item.data.category === product.data.category && item.id !== product.id)
  .sort((a, b) => {
    const orderDiff = (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER);

    if (orderDiff !== 0) {
      return orderDiff;
    }

    return a.data.model.localeCompare(b.data.model, "zh-Hant-TW");
  })
  .slice(0, 4);

const productPath = (id: string) => {
  const [itemCategory, itemSlug] = id.split("/");
  return `/products/${itemCategory}/${itemSlug}/`;
};

const productSearchText = (item: (typeof relatedProducts)[number]) =>
  `${item.data.model} ${item.data.title} ${item.data.brand ?? ""}`.toLowerCase();

const brandName = product.data.brand?.trim();
const pageTitle = [brandName, product.data.model, product.data.title].filter(Boolean).join(" ");
const pageDescription = [
  `${pageTitle}。`,
  product.data.features[0] ? `${product.data.features[0]}。` : "",
  `耕紋貿易專業代理測試測量儀器，北中南三據點提供選型報價與維修保固服務。`,
].join("");

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${product.data.model} ${product.data.title}`,
  model: product.data.model,
  ...(brandName ? { brand: { "@type": "Brand", name: brandName } } : {}),
  image: new URL(withBase(product.data.image), Astro.site).href,
  description: pageDescription,
  ...(category ? { category: category.name } : {}),
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: new URL(withBase("/"), Astro.site).href },
    { "@type": "ListItem", position: 2, name: "產品介紹", item: new URL(withBase("/products/"), Astro.site).href },
    ...(category
      ? [
          {
            "@type": "ListItem",
            position: 3,
            name: category.name,
            item: new URL(withBase(`/products/${category.slug}/`), Astro.site).href,
          },
        ]
      : []),
    { "@type": "ListItem", position: category ? 4 : 3, name: product.data.model },
  ],
});
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={withBase("/")}>首頁</a>
        <span aria-hidden="true">›</span>
        <a href={withBase("/products/")}>產品介紹</a>
        <span aria-hidden="true">›</span>
        {
          category ? (
            <a href={withBase(`/products/${category.slug}/`)}>{category.name}</a>
          ) : (
            <span>{product.data.category}</span>
          )
        }
        <span aria-hidden="true">›</span>
        <span>{product.data.model}</span>
      </nav>

      <article class="product-detail">
        <button
          class="product-detail__media"
          type="button"
          data-lightbox-open
          aria-haspopup="dialog"
          aria-label={`放大檢視 ${product.data.model} 產品圖片`}
        >
          <img
            src={withBase(product.data.image)}
            alt={`${product.data.model} ${product.data.title} 產品圖片`}
            loading="lazy"
            decoding="async"
          />
          <span class="product-detail__zoom" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="M16.5 16.5L21 21M11 8v6M8 11h6"></path>
            </svg>
            點圖放大
          </span>
        </button>

        <div class="card product-detail__info">
          <p class="eyebrow">{brandName ?? "Product"}</p>
          <h1>{product.data.title}</h1>
          <dl class="product-meta">
            <div>
              <dt>型號</dt>
              <dd class="product-meta__model">{product.data.model}</dd>
            </div>
            {
              product.data.brand && (
                <div>
                  <dt>品牌</dt>
                  <dd>{product.data.brand}</dd>
                </div>
              )
            }
          </dl>

          {
            product.data.features.length > 0 && (
              <ul class="feature-list" aria-label="產品特色">
                {product.data.features.map((feature) => (
                  <li>
                    <span aria-hidden="true">◆</span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            )
          }

          {
            product.body?.trim() && (
              <div class="product-body">
                <Content />
              </div>
            )
          }

          <div class="product-actions">
            <button
              class="btn btn-accent product-add"
              type="button"
              data-inquiry-add
              data-slug={product.id}
              data-model={product.data.model}
              data-title={product.data.title}
            >
              加入詢價單
            </button>
            <a class="btn" href={withBase("/contact/")}>聯絡我們詢問</a>
          </div>
        </div>
      </article>

      <script type="application/ld+json" set:html={jsonLd} is:inline />
      <script type="application/ld+json" set:html={breadcrumbJsonLd} is:inline />

      <dialog class="lightbox" data-lightbox aria-label={`${product.data.model} ${product.data.title} 大圖檢視`}>
        <button class="lightbox__close" type="button" data-lightbox-close aria-label="關閉大圖">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
        <img
          src={withBase(product.data.image)}
          alt={`${product.data.model} ${product.data.title} 產品圖片大圖`}
          decoding="async"
        />
        <p class="lightbox__caption">{product.data.model}｜{product.data.title}</p>
      </dialog>
    </div>
  </section>

  {
    relatedProducts.length > 0 && (
      <section class="section section-muted">
        <div class="container">
          <div class="section-title">
            <p class="eyebrow">Related Products</p>
            <h2>同分類其他產品</h2>
          </div>
          <div class="related-grid">
            {relatedProducts.map((item) => (
              <ProductCard
                href={productPath(item.id)}
                image={item.data.image}
                model={item.data.model}
                title={item.data.title}
                brand={item.data.brand}
                slug={item.id}
                search={productSearchText(item)}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>

<script>
  const opener = document.querySelector<HTMLButtonElement>("[data-lightbox-open]");
  const dialog = document.querySelector<HTMLDialogElement>("[data-lightbox]");
  const closeButton = dialog?.querySelector<HTMLButtonElement>("[data-lightbox-close]");
  const image = dialog?.querySelector<HTMLImageElement>("img");

  if (opener && dialog) {
    opener.addEventListener("click", () => {
      // 舊產品圖解析度低，放大上限訂為原圖 2 倍，避免過度模糊
      if (image?.naturalWidth) {
        image.style.maxWidth = `min(100%, ${image.naturalWidth * 2}px)`;
        image.style.maxHeight = `min(72vh, ${image.naturalHeight * 2}px)`;
      }

      dialog.showModal();
    });

    closeButton?.addEventListener("click", () => dialog.close());

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }
</script>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: var(--space-3);
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .breadcrumb a {
    color: var(--color-primary);
    font-weight: 700;
  }

  .product-detail {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
    gap: var(--space-4);
    align-items: start;
  }

  .product-detail__media {
    position: relative;
    display: flex;
    aspect-ratio: 4 / 3;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: var(--shadow-card);
    cursor: zoom-in;
    transition: border-color 140ms ease, box-shadow 140ms ease;
  }

  .product-detail__media:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  .product-detail__media img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .product-detail__zoom {
    position: absolute;
    right: 0.75rem;
    bottom: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .product-detail__zoom svg {
    width: 15px;
    height: 15px;
  }

  .product-detail__media:hover .product-detail__zoom {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .lightbox {
    max-width: min(92vw, 1000px);
    padding: var(--space-3);
    border: none;
    border-radius: var(--radius-card);
    background: #ffffff;
    box-shadow: 0 24px 64px rgba(8, 31, 58, 0.4);
  }

  .lightbox::backdrop {
    background: rgba(8, 31, 58, 0.72);
  }

  .lightbox img {
    margin-inline: auto;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 72vh;
    object-fit: contain;
  }

  .lightbox__caption {
    margin: var(--space-2) 0 0;
    color: var(--color-primary-dark);
    font-weight: 700;
    text-align: center;
  }

  .lightbox__close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #ffffff;
    color: var(--color-primary-dark);
    cursor: pointer;
    transition: background-color 120ms ease, color 120ms ease, border-color 120ms ease;
  }

  .lightbox__close:hover {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #ffffff;
  }

  .lightbox__close svg {
    width: 20px;
    height: 20px;
  }

  .product-detail__info {
    padding: var(--space-4);
  }

  .product-detail__info h1 {
    margin-bottom: var(--space-2);
  }

  .product-meta {
    display: grid;
    gap: var(--space-1);
    margin: 0 0 var(--space-3);
  }

  .product-meta div {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: var(--space-1);
    align-items: baseline;
  }

  .product-meta dt {
    color: var(--color-muted);
    font-weight: 700;
  }

  .product-meta dd {
    margin: 0;
    color: var(--color-primary-dark);
    font-weight: 800;
  }

  .product-meta__model {
    font-family: var(--font-mono);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .feature-list {
    display: grid;
    gap: 0.65rem;
    margin: 0 0 var(--space-3);
    padding: 0;
    list-style: none;
  }

  .feature-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.5rem;
    color: var(--color-text);
  }

  .feature-list span[aria-hidden="true"] {
    color: var(--color-accent);
    font-size: 0.85rem;
    line-height: 1.9;
  }

  .product-body {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .product-body :global(:last-child) {
    margin-bottom: 0;
  }

  .product-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .product-add {
    min-width: 180px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }

  @media (max-width: 960px) {
    .product-detail,
    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .product-detail__info {
      padding: var(--space-3);
    }
  }

  @media (max-width: 768px) {
    .product-detail,
    .related-grid {
      grid-template-columns: 1fr;
    }

    .product-actions {
      display: grid;
    }
  }
</style>
